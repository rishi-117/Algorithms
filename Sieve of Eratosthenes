#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cout << "Enter limit (<= 1e7): ";
    cin >> n;

    if (n < 2) {
        cout << "No primes exist below 2.\n";
        return 0;
    }

    vector<char> prichk(n + 1, true);
    prichk[0] = prichk[1] = false;

    int limit = (int)floor(sqrt(n));
    for (int p = 2; p <= limit; ++p) {
        if (prichk[p]) {
            for (long long j = 1LL * p * p; j <= n; j += p)
                prichk[(int)j] = false;
        }
    }

    cout << "Primes up to " << n << ":\n";
    for (int i = 2; i <= n; ++i) {
        if (prichk[i]) cout << i << ' ';
    }
    cout << '\n';

    return 0;
}
